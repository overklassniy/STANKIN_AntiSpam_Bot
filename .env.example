# Скопируйте этот файл в .env и заполните значения

# DATABASE
# Строка подключения к PostgreSQL
DATABASE_URL=postgresql://sass:postgres_password@localhost:5432/stankin_antispam

# TELEGRAM BOT
# Токен бота от @BotFather
BOT_TOKEN=bot_token

# Токен тестового бота (для режима TESTING)
TEST_BOT_TOKEN=test_bot_token

# TELEGRAM CHATS
# ID чата для уведомлений (чат управления)
NOTIFICATION_CHAT_ID=-1001234567890

# ID тредов для уведомлений (topic ID в супергруппах)
NOTIFICATION_CHAT_98_SPAM_THREAD=1
NOTIFICATION_CHAT_94_SPAM_THREAD=2
NOTIFICATION_CHAT_NS_SPAM_THREAD=3
NOTIFICATION_CHAT_MUTED_THREAD=4

# ID треда для отправки резервных копий базы данных
NOTIFICATION_CHAT_BACKUP_THREAD=5

# OPENAI (опционально)
# API ключ OpenAI для ChatGPT анализа
# Если не указан, ChatGPT проверка будет отключена
# OPENAI_API_KEY=sk-openai-api-key

# FLASK / WEB PANEL
# Секретный ключ Flask
SECRET_KEY=secret-key

# Пароль администратора панели управления
ADMIN_PASSWORD=admin-password

# Порт панели управления
PANEL_PORT=12523

# Время жизни сессии (минуты)
PERMANENT_SESSION_LIFETIME=60

# Время жизни cookie "Запомнить меня" (минуты, 10080 = 7 дней)
REMEMBER_COOKIE_DURATION=10080

# PATHS
# Директория для логов (относительно корня проекта)
LOGS_DIR=logs

# Директория с ML моделями (относительно корня проекта)
MODELS_DIR=models

# Путь к BERT модели (относительно корня проекта)
BERT_MODEL=models/finetuned_rubert_tiny2

# PROXY (optional)
# SOCKS5 прокси для Telegram Bot API
# Формат: socks5://user:password@host:port или socks5://host:port
# PROXY_URL=socks5://user:password@host:port

# MODE
# Режим тестирования (true/false)
# В тестовом режиме проверяются все сообщения, включая от администраторов
TESTING=false

# SUPPORT
# Email технической поддержки (отображается в сообщениях об ошибках)
HELPDESK_EMAIL=support@example.com

# MONITORING
# DSN для Sentry (опционально, для мониторинга ошибок)
# Если не указан, мониторинг Sentry отключён
# SENTRY_DSN=https://sentry-dsn@sentry.io/project-id

# Процент трейс-сессий для Sentry (0.0–1.0)
# 1.0 = все запросы, 0.1 = 10% запросов
SENTRY_TRACES_SAMPLE_RATE=0.1

# Включить отправку логов в Sentry (true/false)
# Требует Sentry SDK 2.35.0+ и активации Sentry Logs в настройках проекта
# https://docs.sentry.io/platforms/python/logs/
SENTRY_ENABLE_LOGS=false

# Уровень логов, отправляемых в Sentry как structured logs
# Возможные значения: DEBUG, INFO, WARNING, ERROR, CRITICAL
SENTRY_LOGS_LEVEL=INFO

# Уровень логов, записываемых как breadcrumbs (контекст к событиям)
# Возможные значения: DEBUG, INFO, WARNING, ERROR, CRITICAL
SENTRY_BREADCRUMBS_LEVEL=INFO

# Уровень логов, отправляемых в Sentry как events (ошибки)
# Возможные значения: DEBUG, INFO, WARNING, ERROR, CRITICAL
SENTRY_EVENT_LEVEL=ERROR
